import { useState, useMemo } from 'react'
import { load, save, KEYS } from '../utils/storage.js'
import { fmt } from '../utils/calculations.js'
import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from 'recharts'

const EMPTY_ENTRY = {
  date: new Date().toISOString().split('T')[0],
  qty: '', buyPrice: '', sellPrice: '',
  transport: '', broker: '', storage: '', misc: '',
  notes: ''
}

export default function Financials({ showToast }) {
  const [entries, setEntries] = useState(() => load(KEYS.FINANCIALS, []))
  const [form, setForm] = useState(EMPTY_ENTRY)
  const [tab, setTab] = useState('pnl')

  const set = (k, v) => setForm(p => ({ ...p, [k]: v }))
  const pf = v => parseFloat(v) || 0

  const addEntry = () => {
    if (!pf(form.qty) || !pf(form.buyPrice) || !pf(form.sellPrice)) {
      showToast('Fill Qty, Buy Price, Sell Price', 'error')
      return
    }
    const qty = pf(form.qty)
    const revenue = pf(form.sellPrice) * qty
    const cogs = pf(form.buyPrice) * qty
    const transport = pf(form.transport) * qty
    const broker = pf(form.broker) * qty
    const storage = pf(form.storage) * qty
    const misc = pf(form.misc)
    const grossProfit = revenue - cogs
    const totalCosts = transport + broker + storage + misc
    const netProfit = grossProfit - totalCosts
    const margin = revenue > 0 ? (netProfit / revenue) * 100 : 0

    const entry = { ...form, id: Date.now(), qty, revenue, cogs, grossProfit, totalCosts, netProfit, margin }
    const updated = [...entries, entry]
    setEntries(updated)
    save(KEYS.FINANCIALS, updated)
    setForm(EMPTY_ENTRY)
    showToast('Entry added', 'success')
  }

  const deleteEntry = (id) => {
    const updated = entries.filter(e => e.id !== id)
    setEntries(updated)
    save(KEYS.FINANCIALS, updated)
  }

  const totals = useMemo(() => {
    if (!entries.length) return null
    return entries.reduce((acc, e) => ({
      revenue: acc.revenue + e.revenue,
      cogs: acc.cogs + e.cogs,
      grossProfit: acc.grossProfit + e.grossProfit,
      totalCosts: acc.totalCosts + e.totalCosts,
      netProfit: acc.netProfit + e.netProfit,
      qty: acc.qty + e.qty
    }), { revenue: 0, cogs: 0, grossProfit: 0, totalCosts: 0, netProfit: 0, qty: 0 })
  }, [entries])

  const chartData = useMemo(() => {
    return entries.slice(-12).map((e, i) => ({
      name: e.date?.slice(5) || `T${i + 1}`,
      revenue: Math.round(e.revenue),
      netProfit: Math.round(e.netProfit),
      cogs: Math.round(e.cogs)
    }))
  }, [entries])

  return (
    <div>
      <div className="module-header">
        <div>
          <div className="module-title">💼 Financial Statements</div>
          <div className="module-subtitle">P&L · Cost structure · Revenue tracking</div>
        </div>
        {totals && (
          <span className={`badge ${totals.netProfit >= 0 ? 'badge-green' : 'badge-red'}`}>
            {fmt.currency(totals.netProfit, 0)}
          </span>
        )}
      </div>

      <div className="tab-row">
        {[['pnl', '📊 P&L'], ['add', '➕ Add Entry'], ['chart', '📈 Charts']].map(([id, label]) => (
          <button key={id} className={`tab ${tab === id ? 'active' : ''}`} onClick={() => setTab(id)}>
            {label}
          </button>
        ))}
      </div>

      {tab === 'add' && (
        <div className="card">
          <div className="section-label">📝 New Trade Entry</div>
          <div className="input-row">
            <div className="input-group">
              <label className="input-label">Date</label>
              <input className="input-field" type="date" value={form.date} onChange={e => set('date', e.target.value)} />
            </div>
            <div className="input-group">
              <label className="input-label">Quantity (kg)</label>
              <input className="input-field" type="number" step="100" placeholder="5000"
                value={form.qty} onChange={e => set('qty', e.target.value)} />
            </div>
          </div>
          <div className="input-row">
            <div className="input-group">
              <label className="input-label">Buy Price (₹/kg)</label>
              <input className="input-field" type="number" step="0.25" placeholder="92.00"
                value={form.buyPrice} onChange={e => set('buyPrice', e.target.value)} />
            </div>
            <div className="input-group">
              <label className="input-label">Sell Price (₹/kg)</label>
              <input className="input-field" type="number" step="0.25" placeholder="96.50"
                value={form.sellPrice} onChange={e => set('sellPrice', e.target.value)} />
            </div>
          </div>
          <div className="input-row-3">
            <div className="input-group">
              <label className="input-label">Transport (₹/kg)</label>
              <input className="input-field" type="number" step="0.05" placeholder="0.80"
                value={form.transport} onChange={e => set('transport', e.target.value)} />
            </div>
            <div className="input-group">
              <label className="input-label">Broker (₹/kg)</label>
              <input className="input-field" type="number" step="0.05" placeholder="0.30"
                value={form.broker} onChange={e => set('broker', e.target.value)} />
            </div>
            <div className="input-group">
              <label className="input-label">Storage (₹/kg)</label>
              <input className="input-field" type="number" step="0.05" placeholder="0.10"
                value={form.storage} onChange={e => set('storage', e.target.value)} />
            </div>
          </div>
          <div className="input-row">
            <div className="input-group">
              <label className="input-label">Misc Fixed Costs (₹)</label>
              <input className="input-field" type="number" step="100" placeholder="500"
                value={form.misc} onChange={e => set('misc', e.target.value)} />
            </div>
            <div className="input-group">
              <label className="input-label">Notes</label>
              <input className="input-field" type="text" placeholder="Optional"
                value={form.notes} onChange={e => set('notes', e.target.value)} />
            </div>
          </div>
          <button className="btn btn-primary btn-full" onClick={addEntry}>
            ➕ Add Entry
          </button>
        </div>
      )}

      {tab === 'pnl' && (
        <>
          {totals ? (
            <>
              {/* Summary P&L */}
              <div className="card module-section">
                <div className="card-title mb-3">📊 Consolidated P&L</div>
                {[
                  { label: 'Revenue', value: totals.revenue, color: 'var(--green)' },
                  { label: 'Cost of Goods (COGS)', value: -totals.cogs, color: 'var(--red)', isDash: true },
                  { label: 'Gross Profit', value: totals.grossProfit, color: totals.grossProfit >= 0 ? 'var(--gold)' : 'var(--red)', bold: true },
                  { label: 'Operating Costs', value: -totals.totalCosts, color: 'var(--red)', isDash: true },
                  { label: 'Net Profit', value: totals.netProfit, color: totals.netProfit >= 0 ? 'var(--green)' : 'var(--red)', bold: true, big: true },
                ].map((r, i) => (
                  <div key={i} style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: `${r.big ? 12 : 8}px 0`, borderBottom: i < 4 ? '1px solid var(--border)' : 'none', ...(r.bold ? { borderTop: '1px solid var(--border-light)' } : {}) }}>
                    <span style={{ fontSize: r.big ? 13 : 12, fontWeight: r.bold ? 600 : 400, color: 'var(--text-2)' }}>
                      {r.isDash ? '  — ' : ''}{r.label}
                    </span>
                    <span style={{ fontSize: r.big ? 18 : 14, fontWeight: r.bold ? 700 : 600, fontFamily: 'var(--font-mono)', color: r.color }}>
                      {fmt.currency(Math.abs(r.value), 0)}{r.isDash ? ' ↓' : ''}
                    </span>
                  </div>
                ))}
                <div style={{ marginTop: 12, padding: 10, background: 'var(--bg-3)', borderRadius: 8, display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                  <span style={{ fontSize: 12, color: 'var(--text-3)' }}>Net Margin</span>
                  <span style={{ fontSize: 16, fontWeight: 700, color: 'var(--gold)', fontFamily: 'var(--font-mono)' }}>
                    {fmt.pct(totals.revenue > 0 ? (totals.netProfit / totals.revenue) * 100 : 0, 2)}
                  </span>
                </div>
              </div>

              {/* Trade Entries Table */}
              <div className="card">
                <div className="card-title mb-3">Trade Ledger ({entries.length} entries)</div>
                <div className="table-wrap">
                  <table>
                    <thead>
                      <tr>
                        <th>Date</th>
                        <th>Qty (kg)</th>
                        <th>Buy</th>
                        <th>Sell</th>
                        <th>Gross</th>
                        <th>Net P&L</th>
                        <th>Margin%</th>
                        <th></th>
                      </tr>
                    </thead>
                    <tbody>
                      {[...entries].reverse().map(e => (
                        <tr key={e.id}>
                          <td style={{ fontSize: 11 }}>{e.date}</td>
                          <td className="mono">{e.qty.toLocaleString()}</td>
                          <td className="mono">{fmt.currency(pf(e.buyPrice))}</td>
                          <td className="mono">{fmt.currency(pf(e.sellPrice))}</td>
                          <td className="mono" style={{ color: 'var(--gold)' }}>{fmt.currency(e.grossProfit, 0)}</td>
                          <td className="mono" style={{ color: e.netProfit >= 0 ? 'var(--green)' : 'var(--red)', fontWeight: 700 }}>
                            {fmt.currency(e.netProfit, 0)}
                          </td>
                          <td className="mono" style={{ color: e.margin >= 3 ? 'var(--green)' : e.margin >= 0 ? 'var(--gold)' : 'var(--red)' }}>
                            {fmt.pct(e.margin, 1)}
                          </td>
                          <td><button onClick={() => deleteEntry(e.id)} style={{ background: 'none', border: 'none', color: 'var(--text-4)', cursor: 'pointer' }}>🗑</button></td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </>
          ) : (
            <div className="card" style={{ textAlign: 'center', padding: 48, color: 'var(--text-3)' }}>
              <div style={{ fontSize: 36, marginBottom: 12 }}>💼</div>
              <div>No entries yet. Use the "Add Entry" tab to log trades.</div>
            </div>
          )}
        </>
      )}

      {tab === 'chart' && chartData.length > 0 && (
        <div className="card">
          <div className="card-title mb-3">Revenue vs Cost vs Net Profit</div>
          <div className="chart-container" style={{ height: 260 }}>
            <ResponsiveContainer width="100%" height="100%">
              <BarChart data={chartData} margin={{ top: 4, right: 4, bottom: 0, left: 0 }} barSize={12}>
                <CartesianGrid strokeDasharray="3 3" stroke="var(--border)" vertical={false} />
                <XAxis dataKey="name" stroke="transparent" tick={{ fill: 'var(--text-3)', fontSize: 10 }} />
                <YAxis stroke="transparent" tick={{ fill: 'var(--text-3)', fontSize: 10 }} tickFormatter={v => `₹${(v / 1000).toFixed(0)}k`} />
                <Tooltip formatter={(v, n) => [fmt.currency(v, 0), n]} contentStyle={{ background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 8, fontFamily: 'var(--font-mono)', fontSize: 11 }} />
                <Bar dataKey="cogs" name="COGS" fill="#FF4757" opacity={0.7} radius={[3, 3, 0, 0]} />
                <Bar dataKey="revenue" name="Revenue" fill="#D4A830" opacity={0.8} radius={[3, 3, 0, 0]} />
                <Bar dataKey="netProfit" name="Net Profit" fill="#00E5A0" radius={[3, 3, 0, 0]} />
              </BarChart>
            </ResponsiveContainer>
          </div>
        </div>
      )}
    </div>
  )
}
