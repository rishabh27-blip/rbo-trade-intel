import { useState, useMemo } from 'react'
import { buildScenarios, fmt } from '../utils/calculations.js'
import { RadarChart, Radar, PolarGrid, PolarAngleAxis, PolarRadiusAxis, ResponsiveContainer, Tooltip } from 'recharts'

export default function Scenarios({ showToast }) {
  const [inputs, setInputs] = useState({
    buyPrice: '92.00', sellPrice: '96.50',
    qty: '5000', transport: '0.80',
    broker: '0.30', holding: '3'
  })
  const [ran, setRan] = useState(false)

  const set = (k, v) => setInputs(p => ({ ...p, [k]: v }))
  const pf = v => parseFloat(v) || 0

  const scenarios = useMemo(() => {
    if (!ran) return null
    return buildScenarios({
      buyPrice: pf(inputs.buyPrice),
      sellPrice: pf(inputs.sellPrice),
      qty: pf(inputs.qty),
      transport: pf(inputs.transport),
      broker: pf(inputs.broker),
      holding: pf(inputs.holding)
    })
  }, [ran, inputs])

  const run = () => {
    if (!pf(inputs.buyPrice) || !pf(inputs.sellPrice)) {
      showToast('Fill prices', 'error'); return
    }
    setRan(true)
  }

  const sensData = useMemo(() => {
    if (!pf(inputs.buyPrice) || !pf(inputs.sellPrice) || !pf(inputs.qty)) return []
    const base = { buy: pf(inputs.buyPrice), sell: pf(inputs.sellPrice), qty: pf(inputs.qty), t: pf(inputs.transport), b: pf(inputs.broker) }
    return [-4, -3, -2, -1, 0, 1, 2, 3, 4].map(delta => {
      const sell = base.sell * (1 + delta / 100)
      const profit = (sell - base.buy - base.t - base.b) * base.qty
      return { delta: `${delta > 0 ? '+' : ''}${delta}%`, profit: Math.round(profit) }
    })
  }, [inputs])

  const ScenarioCard = ({ label, data, colorClass, icon, detail }) => (
    <div style={{
      background: 'var(--bg-3)',
      border: `1px solid ${
        colorClass === 'green' ? 'var(--green-dim)' :
        colorClass === 'red' ? 'var(--red-dim)' : 'var(--gold-dim)'
      }`,
      borderRadius: 10, padding: 16,
  
    }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 12 }}>
        <div>
          <div style={{ fontSize: 14, fontWeight: 700, color: 'var(--text-1)' }}>{icon} {label}</div>
          <div style={{ fontSize: 11, color: 'var(--text-3)', fontFamily: 'var(--font-mono)', marginTop: 2 }}>{detail}</div>
        </div>
        <div style={{ textAlign: 'right' }}>
          <div style={{ fontSize: 20, fontWeight: 800, fontFamily: 'var(--font-mono)', color: data.profit >= 0 ? 'var(--green)' : 'var(--red)' }}>
            {fmt.currency(data.profit, 0)}
          </div>
          <div style={{ fontSize: 11, color: 'var(--text-3)', fontFamily: 'var(--font-mono)' }}>Net Profit</div>
        </div>
      </div>
      <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8 }}>
        <div style={{ fontSize: 11, color: 'var(--text-3)' }}>
          <span style={{ fontFamily: 'var(--font-mono)' }}>Sell: </span>
          <span style={{ color: 'var(--text-1)', fontWeight: 600, fontFamily: 'var(--font-mono)' }}>{fmt.currency(data.sell)}</span>
        </div>
        <div style={{ fontSize: 11, color: 'var(--text-3)' }}>
          <span style={{ fontFamily: 'var(--font-mono)' }}>Margin/kg: </span>
          <span style={{ color: data.margin >= 0 ? 'var(--gold)' : 'var(--red)', fontWeight: 600, fontFamily: 'var(--font-mono)' }}>
            {fmt.currency(data.margin)}
          </span>
        </div>
      </div>
    </div>
  )

  return (
    <div>
      <div className="module-header">
        <div>
          <div className="module-title">🔮 Scenario Forecasting</div>
          <div className="module-subtitle">Bear / Base / Bull case modeling + sensitivity analysis</div>
        </div>
      </div>

      {/* Inputs */}
      <div className="card module-section">
        <div className="section-label">📐 Base Case Parameters</div>
        <div className="input-row">
          <div className="input-group">
            <label className="input-label">Buy Price (₹/kg)</label>
            <input className="input-field" type="number" step="0.25" value={inputs.buyPrice}
              onChange={e => { set('buyPrice', e.target.value); setRan(false) }} />
          </div>
          <div className="input-group">
            <label className="input-label">Expected Sell (₹/kg)</label>
            <input className="input-field" type="number" step="0.25" value={inputs.sellPrice}
              onChange={e => { set('sellPrice', e.target.value); setRan(false) }} />
          </div>
        </div>
        <div className="input-row">
          <div className="input-group">
            <label className="input-label">Quantity (kg)</label>
            <input className="input-field" type="number" step="100" value={inputs.qty}
              onChange={e => { set('qty', e.target.value); setRan(false) }} />
          </div>
          <div className="input-group">
            <label className="input-label">Transport (₹/kg)</label>
            <input className="input-field" type="number" step="0.1" value={inputs.transport}
              onChange={e => { set('transport', e.target.value); setRan(false) }} />
          </div>
        </div>
        <div className="input-row">
          <div className="input-group">
            <label className="input-label">Broker (₹/kg)</label>
            <input className="input-field" type="number" step="0.1" value={inputs.broker}
              onChange={e => { set('broker', e.target.value); setRan(false) }} />
          </div>
          <div className="input-group">
            <label className="input-label">Holding Days</label>
            <input className="input-field" type="number" step="1" value={inputs.holding}
              onChange={e => { set('holding', e.target.value); setRan(false) }} />
          </div>
        </div>
        <button className="btn btn-primary btn-full" onClick={run}>
          🔮 Run Scenarios
        </button>
      </div>

      {/* Scenario Cards */}
      {scenarios && (
        <>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr', gap: 10 }} className="module-section">
            <ScenarioCard label="Extreme Bear" data={scenarios.extreme_bear} colorClass="red" icon="🐻" detail="-6% sell price" />
            <ScenarioCard label="Bear Case" data={scenarios.bear} colorClass="red" icon="📉" detail="-3% sell price" />
            <ScenarioCard label="Base Case" data={scenarios.base} colorClass="gold" icon="📊" detail="No change" />
            <ScenarioCard label="Bull Case" data={scenarios.bull} colorClass="green" icon="📈" detail="+3% sell price" />
            <ScenarioCard label="Extreme Bull" data={scenarios.extreme_bull} colorClass="green" icon="🚀" detail="+6% sell price" />
          </div>

          {/* Break-even analysis */}
          <div className="card module-section">
            <div className="section-label">🎯 Break-Even Analysis</div>
            {(() => {
              const buy = pf(inputs.buyPrice)
              const t = pf(inputs.transport)
              const b = pf(inputs.broker)
              const breakEven = buy + t + b
              const currentSell = pf(inputs.sellPrice)
              const cushion = currentSell - breakEven
              return (
                <>
                  <div style={{ display: 'flex', justifyContent: 'space-between', padding: '10px 0', borderBottom: '1px solid var(--border)' }}>
                    <span style={{ fontSize: 12, color: 'var(--text-2)' }}>Break-Even Price</span>
                    <span style={{ fontSize: 16, fontWeight: 700, color: 'var(--gold)', fontFamily: 'var(--font-mono)' }}>
                      {fmt.currency(breakEven)}
                    </span>
                  </div>
                  <div style={{ display: 'flex', justifyContent: 'space-between', padding: '10px 0', borderBottom: '1px solid var(--border)' }}>
                    <span style={{ fontSize: 12, color: 'var(--text-2)' }}>Expected Sell</span>
                    <span style={{ fontSize: 16, fontWeight: 700, color: 'var(--text-1)', fontFamily: 'var(--font-mono)' }}>
                      {fmt.currency(currentSell)}
                    </span>
                  </div>
                  <div style={{ display: 'flex', justifyContent: 'space-between', padding: '10px 0' }}>
                    <span style={{ fontSize: 12, color: 'var(--text-2)' }}>Margin Cushion</span>
                    <span style={{ fontSize: 16, fontWeight: 700, color: cushion >= 1.5 ? 'var(--green)' : cushion >= 0.5 ? 'var(--gold)' : 'var(--red)', fontFamily: 'var(--font-mono)' }}>
                      {fmt.currency(cushion)} ({fmt.pct(currentSell > 0 ? (cushion / currentSell) * 100 : 0, 1)})
                    </span>
                  </div>
                  <div className={`warning-item ${cushion >= 1.5 ? 'success' : cushion >= 0.5 ? 'warn' : ''}`} style={{ marginTop: 8 }}>
                    {cushion >= 2 ? '✅ Strong cushion — can absorb 2% adverse move' :
                     cushion >= 1 ? '⚠️ Moderate cushion — monitor closely' :
                     '❌ Thin cushion — small adverse move wipes profit'}
                  </div>
                </>
              )
            })()}
          </div>

          {/* Sensitivity Chart */}
          {sensData.length > 0 && (
            <div className="card">
              <div className="section-label">📉 Price Sensitivity (Sell Price % Move)</div>
              <div style={{ overflowX: 'auto', marginTop: 12 }}>
                <table style={{ width: '100%' }}>
                  <thead>
                    <tr>
                      <th>Sell Δ</th>
                      <th>Net Profit</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    {sensData.map((row, i) => (
                      <tr key={i}>
                        <td className="mono" style={{ color: parseInt(row.delta) >= 0 ? 'var(--green)' : 'var(--red)' }}>
                          {row.delta}
                        </td>
                        <td className="mono" style={{ fontWeight: 700, color: row.profit >= 0 ? 'var(--green)' : 'var(--red)' }}>
                          {fmt.currency(row.profit, 0)}
                        </td>
                        <td>
                          <span className={`badge ${row.profit >= 5000 ? 'badge-green' : row.profit >= 0 ? 'badge-gold' : 'badge-red'}`}
                            style={{ fontSize: 9 }}>
                            {row.profit >= 5000 ? 'STRONG' : row.profit >= 0 ? 'VIABLE' : 'LOSS'}
                          </span>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}
        </>
      )}
    </div>
  )
}
